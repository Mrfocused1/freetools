# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Stripe =====
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in Stripe dashboard after running migrations)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_CREDITS_SMALL=price_...   # 100 credits / $5
STRIPE_PRICE_CREDITS_LARGE=price_...   # 1000 credits / $40

# ===== Redis (shared by web and worker) =====
REDIS_URL=redis://localhost:6379

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Turnstile (Cloudflare abuse prevention) =====
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===== Worker (set on vast.ai instance only) =====
# REDIS_URL=redis://hetzner-public-ip:6379  (protected by firewall + password)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# WORKER_ID=vast-worker-1
