# Point at the public IP of the Hetzner box where Redis runs.
# Protect Redis with a password (requirepass) and/or a firewall rule that only
# allows inbound 6379 from the vast.ai instance IP.
REDIS_URL=redis://:PASSWORD@HETZNER_IP:6379

# Supabase service-role (for Storage read/write on behalf of the worker).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Per-worker id, used in logs and stored on processed jobs.
WORKER_ID=vast-worker-1

# Device: 'cuda' on vast.ai, 'cpu' for local dev.
DEVICE=cuda

# Model cache location (persistent volume if possible)
MODEL_CACHE_DIR=/root/.cache/huggingface

# Port for the health endpoint
PORT=8000
